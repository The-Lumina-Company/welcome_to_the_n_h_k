Dialogue: 0,0:00:12.82,0:00:16.03,OP,,0,0,0,,Göğe bakar düşünürüm{少し見上げた空}
Dialogue: 0,0:00:16.03,0:00:19.07,OP,,0,0,0,,Hayatım ne vakit dibi boylayacak{出来過ぎた日常}
Dialogue: 0,0:00:19.07,0:00:24.20,OP,,0,0,0,,Sırtımı semaya dönmeden iç çekerim{背を向ける度に　呟くだけ}
Dialogue: 0,0:00:24.20,0:00:27.79,OP,,0,0,0,,Nereye döner isem de{どこに行けばいいの？}
Dialogue: 0,0:00:27.79,0:00:33.10,OP,,0,0,0,,Özellikle sen öyle bakarken bana{そんな顔してる君と}
Dialogue: 0,0:00:37.14,0:00:39.12,OP,,0,0,0,,Gölgeler sokak arakalarında{路地裏の陰}
Dialogue: 0,0:00:39.12,0:00:42.32,OP,,0,0,0,,Akrep ve yelkovan gibi{時計の針が}
Dialogue: 0,0:00:42.92,0:00:49.39,OP,,0,0,0,,İlerlemeyen zamana bir çekidüzen{止まった時間を　塗り替えて}
Dialogue: 0,0:00:50.15,0:00:57.50,OP,,0,0,0,,Ellerimi bir arada dahi kalamayan bir bulmacaya uzatıyorum{差し延べた両手　噛み合わないパズルを}
Dialogue: 0,0:00:58.78,0:01:05.90,OP,,0,0,0,,Öylece kalabilirim, bir olacağımız güne dek{置き去りにしてた　二人出会うまで}
Dialogue: 0,0:01:06.96,0:01:10.24,OP,,0,0,0,,Ve kaybettiğimiz o son{失くしてた何か}
Dialogue: 0,0:01:10.24,0:01:18.12,OP,,0,0,0,,Parçayı bulmayı{最後のかけらを 取り戻して}
Dialogue: 0,0:01:19.93,0:01:24.26,OP,,0,0,0,,Ve yeni yollara çıkmayı beklerim{歩き出そう}
Dialogue: 0,0:01:30.00,0:01:30.04,OP,chptr,0,0,0,,{Episode}
Dialogue: 0,0:21:59.97,0:22:00.01,OP,chptr,0,0,0,,{ED}
Dialogue: 0,0:22:12.37,0:22:15.35,OP,,0,0,0,,Hebele hübele hebele, dans eden çocuk adam!
Dialogue: 0,0:22:21.45,0:22:24.36,OP,,0,0,0,,Doğduğumuzda, çırılçıpılak olsak
Dialogue: 0,0:22:24.36,0:22:27.38,OP,,0,0,0,,Hepimiz biriz, çok seveceniz
Dialogue: 0,0:22:27.38,0:22:30.27,OP,,0,0,0,,Ama nedense, hayat devam ettikçe
Dialogue: 0,0:22:30.27,0:22:33.28,OP,,0,0,0,,Acımasızlık kontorlü eline alınca kaderlerimiz ayrılıverir
Dialogue: 0,0:22:33.28,0:22:34.91,OP,,0,0,0,,Bazıları diğerlerine bakabilir
Dialogue: 0,0:22:34.91,0:22:36.38,OP,,0,0,0,,Bazıları bakamaz
Dialogue: 0,0:22:36.38,0:22:37.74,OP,,0,0,0,,Bazıları sevmeyi öğrenebilir
Dialogue: 0,0:22:37.74,0:22:39.21,OP,,0,0,0,,Bazıları öğrenemez
Dialogue: 0,0:22:39.21,0:22:40.84,OP,,0,0,0,,Ölene dek
Dialogue: 0,0:22:40.84,0:22:42.29,OP,,0,0,0,,Ölene dek
Dialogue: 0,0:22:42.29,0:22:45.44,OP,,0,0,0,,Çocuk, çocuk adam olurum ben de
Dialogue: 0,0:22:45.44,0:22:51.48,OP,,0,0,0,,"Aman, ne de şirin bi bebek!"
Dialogue: 0,0:22:51.48,0:22:57.42,OP,,0,0,0,,"Sadece seni sevmek isterim!"
Dialogue: 0,0:22:54.35,0:22:55.86,OP,,0,0,0,,{\3c&H16167E&}Tam da planladığım gibi!
Dialogue: 0,0:22:55.86,0:22:57.42,OP,,0,0,0,,{\3c&H16167E&}Mükemmel gidiyor!
Dialogue: 0,0:22:57.42,0:23:00.33,OP,,0,0,0,,Tuttuğu bebek gerçek bir çocuk adam
Dialogue: 0,0:23:00.33,0:23:03.33,OP,,0,0,0,,"Hebele!" hıçkırır yapmacık masumluğumu korurum
Dialogue: 0,0:23:03.33,0:23:06.30,OP,,0,0,0,,Çocuk adam olmak çok kolay, bu yüzden sen de öyle ol!
Dialogue: 0,0:23:06.30,0:23:09.04,OP,,0,0,0,,Hebele hübele! Dans et, çoğal ve uzaya var!
Dialogue: 0,0:23:09.04,0:23:09.77,OP,,0,0,0,,Marsa
Dialogue: 0,0:23:09.77,0:23:10.52,OP,,0,0,0,,Satürne
Dialogue: 0,0:23:10.52,0:23:11.32,OP,,0,0,0,,Tüm galaksiye!
Dialogue: 0,0:23:11.32,0:23:12.07,OP,,0,0,0,,Dans et!
Dialogue: 0,0:23:12.07,0:23:13.55,OP,,0,0,0,,Çocuk adam!
Dialogue: 0,0:23:13.55,0:23:14.24,OP,,0,0,0,,Dans et!
Dialogue: 0,0:23:14.24,0:23:16.23,OP,,0,0,0,,Çocuk adam!
Dialogue: 0,0:23:29.99,0:23:30.03,OP,chptr,0,0,0,,{Preview}
